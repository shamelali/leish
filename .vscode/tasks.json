        "tsx",
        "scripts/validate-translations.ts"
      ],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "i18n: Sync Translations",
      "type": "shell",
      "command": "npx",
      "args": [
        "tsx",
        "scripts/sync-translations.ts"
      ],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
