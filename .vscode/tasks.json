{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "i18n-trans.reload",
      "type": "shell",
      "command": "node",
      "args": [
        "-e",
        "console.log('🔄 i18n translations reloaded at', new Date().toISOString())"
      ],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "i18n: Validate Translations",
      "type": "shell",
      "command": "npx",
